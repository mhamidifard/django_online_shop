# Runtime environment: development | production
DJANGO_ENV=development

# Django
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:8000
PASSWORD_RESET_CONFIRM_PATH=api/auth/password-reset/confirm

# Security flags (set to True in production behind HTTPS)
DJANGO_USE_X_FORWARDED_PROTO=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Django REST Framework
DRF_PAGE_SIZE=20
DRF_THROTTLE_ANON=100/hour
DRF_THROTTLE_USER=1000/hour
DRF_THROTTLE_PASSWORD_RESET=5/hour

# JWT
JWT_ACCESS_MINUTES=90
JWT_REFRESH_DAYS=1

# Database
# Use sqlite in local dev by default, or switch to PostgreSQL.
# DB_ENGINE=django.db.backends.postgresql


# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=

DB_ENGINE=django.db.backends.postgresql
DB_NAME=mydb
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=db
DB_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@example.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Celery Configuration
CELERY_BROKER_URL=amqp://guest:rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_RESULT_EXPIRES=3600
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# Celery Production Settings (optional, for production environment)
# CELERY_BROKER_USE_SSL=False
# CELERY_REDIS_BACKEND_USE_SSL=False
